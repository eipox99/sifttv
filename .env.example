# External URL the app is served from. next-auth uses this to build the OAuth
# redirect, and next.config derives the dev allowed-origin from its hostname.
# Local: http://localhost:3000  |  Remote (Tailscale, HTTPS): https://<name>.ts.net
AUTH_URL=http://localhost:3000
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
AUTH_SECRET=
DATABASE_URL=file:./dev.db
REDIS_URL=
INLINE_REFRESH_JOBS=true
TWITCH_MAX_CRAWL_PAGES=0
# Optional: extra comma-separated hosts allowed to reach the dev server
# (e.g. a LAN IP you also use). AUTH_URL's host is included automatically.
# DEV_ORIGINS=192.168.1.103
