generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  favorites     Favorite[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Favorite {
  id               String   @id @default(cuid())
  userId           String
  channelId        String
  broadcasterLogin String
  broadcasterName  String
  thumbnailUrl     String?
  categoryId       String?
  categoryName     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channelId])
  @@index([userId, createdAt])
}

model CategorySnapshot {
  id             String           @id @default(cuid())
  filtersHash    String
  categoryId     String
  categoryName   String
  language       String?
  streamCount    Int
  duplicateCount Int              @default(0)
  completedAt    DateTime
  createdAt      DateTime         @default(now())
  streams        SnapshotStream[]
  jobs           RefreshJob[]

  @@index([filtersHash, completedAt])
}

model SnapshotStream {
  id               String           @id @default(cuid())
  snapshotId       String
  rank             Int
  streamId         String
  userId           String
  userLogin        String
  userName         String
  title            String
  viewerCount      Int
  startedAt        DateTime
  language         String
  thumbnailUrl     String
  categoryId       String
  categoryName     String
  isMature         Boolean
  tagsJson         String           @default("[]")
  snapshot         CategorySnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@unique([snapshotId, streamId])
  @@index([snapshotId, rank])
}

model RefreshJob {
  id            String            @id @default(cuid())
  filtersHash   String
  categoryId    String
  categoryName  String
  language      String?
  status        String            @default("QUEUED")
  pageCount     Int               @default(0)
  streamCount   Int               @default(0)
  duplicateCount Int              @default(0)
  error         String?
  snapshotId    String?
  startedAt     DateTime?
  completedAt   DateTime?
  failedAt      DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  snapshot      CategorySnapshot? @relation(fields: [snapshotId], references: [id], onDelete: SetNull)

  @@index([filtersHash, createdAt])
  @@index([status, createdAt])
}
